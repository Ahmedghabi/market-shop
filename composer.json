{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "ext-openssl": "*",
    "api-platform/core": "^4.3",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^3.3",
    "intervention/image": "^4.1",
    "nelmio/cors-bundle": "^2.5",
    "symfony/console": "7.4.*",
    "symfony/dotenv": "7.4.*",
    "symfony/expression-language": "^8.1",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "7.4.*",
    "symfony/http-client": "7.4.*",
    "symfony/mercure-bundle": "^0.4.2",
    "symfony/messenger": "7.4.*",
    "symfony/monolog-bundle": "^3.10",
    "symfony/runtime": "7.4.*",
    "symfony/security-bundle": "7.4.*",
    "symfony/serializer": "7.4.*",
    "symfony/translation": "7.4.*",
    "symfony/twig-bundle": "7.4.*",
    "symfony/uid": "7.4.*",
    "symfony/validator": "7.4.*",
    "symfony/var-exporter": "7.4.*",
    "symfony/webpack-encore-bundle": "^2.1",
    "symfony/workflow": "7.4.*",
    "symfony/yaml": "7.4.*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "pestphp/pest": "^2.35",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "symfony/maker-bundle": "^1.67"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/units/src/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "test": "pest --configuration phpunit.xml.dist",
    "phpstan": "phpstan analyse src tests/units/src",
    "cs-check": "php-cs-fixer fix --dry-run --diff"
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true,
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  }
}
